# 后端环境变量示例
# 本地开发：复制为 .env 并填入实际值；生产环境在 Render 控制台配置

# 服务端口（Render 会自动注入 PORT，本地用 8080）
PORT=8080

# 数据库配置（本地 MySQL / 生产环境用 PlanetScale）
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=123456
DB_NAME=pet_medical
# PlanetScale 等云数据库需要 SSL，设为 true
DB_SSL=false

# 前端域名（用于 CORS 白名单，生产环境填 Vercel 域名）
# 本地开发可不填，默认允许 localhost:3000
# 生产环境示例：https://pet-medical-xxx.vercel.app
FRONTEND_URL=

# JWT 密钥
JWT_SECRET=pet_medical_secret_2026
